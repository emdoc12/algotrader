# Copy this to .env and fill in your values

# ── Tastytrade (options + crypto via Tasty) ─────────────────
TT_USERNAME=your-tastytrade-email@example.com
TT_PASSWORD=your-password

# Set to true to use the certification (sandbox) environment
TT_IS_SANDBOX=false

# ── Kraken (24/7 spot crypto) ────────────────────────────────
# Get API keys at: https://pro.kraken.com/app/settings/api
# Required permissions: Query Funds, Create & Modify Orders, Cancel/Close Orders
KRAKEN_API_KEY=your-kraken-api-key
KRAKEN_API_SECRET=your-kraken-api-secret

# ── Bullflow (options flow scanner) ─────────────────────────────────
# Get your API key from: https://bullflow.io/dashboard
BULLFLOW_API_KEY=your-bullflow-api-key

# URL of your running AlgoTrader Node.js server
API_BASE_URL=http://localhost:5000

# DRY_RUN=true means the engine will find opportunities and log them
# but will NOT place real orders. Set to false when ready to go live.
DRY_RUN=true

LOG_LEVEL=INFO
