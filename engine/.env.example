# ============================================================
# AlgoTrader v2.0.0 — Kraken BTC Bot Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- Bot Mode ---
# "paper" = simulated trading (no real money)
# "live"  = real trading on Kraken (requires API keys)
BOT_MODE=paper

# --- Kraken API Credentials ---
# Required for live trading. Paper mode works without these.
# Create API keys at: https://www.kraken.com/u/security/api
# Required permissions: Query Funds, Create & Modify Orders, Cancel/Close Orders
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# --- Trading Pair ---
KRAKEN_SYMBOL=XBTUSD
KRAKEN_DISPLAY_SYMBOL=BTC/USD

# --- Candle Settings ---
# OHLCV candle interval in minutes (1, 5, 15, 30, 60, 240, 1440)
BOT_CANDLE_INTERVAL=15

# --- Strategy: EMA Crossover ---
EMA_FAST_PERIOD=9
EMA_SLOW_PERIOD=21

# --- Strategy: RSI ---
RSI_PERIOD=14
RSI_OVERBOUGHT=70
RSI_OVERSOLD=30

# --- Strategy: Bollinger Bands ---
BB_PERIOD=20
BB_STD_DEV=2.0

# --- Risk Management ---
STOP_LOSS_PCT=3.0
TAKE_PROFIT_PCT=6.0
RISK_PER_TRADE_PCT=2.0
MAX_POSITION_PCT=30.0

# --- Scan Interval ---
# How often (in seconds) the bot checks for signals
SCAN_INTERVAL_SECONDS=60

# --- History ---
# Number of candles to fetch for indicator warmup
HISTORY_BARS=100

# --- Paper Trading ---
PAPER_STARTING_CAPITAL=10000
PAPER_MAKER_FEE_PCT=0.16
PAPER_TAKER_FEE_PCT=0.26

# --- Database ---
BOT_DB_PATH=bot_data.db

# --- Logging ---
# DEBUG, INFO, WARNING, ERROR
BOT_LOG_LEVEL=INFO
